# ─── GEMINI ────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here          # Google AI Studio → API Keys
# Optional: additional keys for rotation (up to 6 free-tier keys)
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=
GEMINI_API_KEY_6=

# ─── SUPABASE ──────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here  # Settings → API → service_role key (NOT anon key)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.your-project.supabase.co:5432/postgres

# ─── REDIS ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# Railway Redis: redis://default:PASSWORD@monorail.proxy.rlwy.net:PORT/0

# ─── EXTERNAL APIS ─────────────────────────────────────────────────
SERPAPI_KEY=your_serpapi_key_here                # serpapi.com → Dashboard → API Key
REDDIT_CLIENT_ID=your_reddit_client_id_here      # reddit.com/prefs/apps → Create App
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here

# ─── APIFY (scraping) ──────────────────────────────────────────────
APIFY_API_TOKEN=your_apify_api_token_here        # apify.com → Settings → API Token
APIFY_AMAZON_ACTOR_ID=codingfrontend/amazon-product-scraper
APIFY_FLIPKART_ACTOR_ID=shahidirfan/flipkart-product-scraper
APIFY_FLIPKART_ACTOR_ID_FALLBACK=maxcopell/flipkart-scraper
APIFY_REVIEWS_ACTOR_ID=junglee/amazon-reviews-scraper
APIFY_WEB_BROWSER_ACTOR_ID=apify/web-scraper

# ─── PAYMENTS ──────────────────────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id_here        # Razorpay Dashboard → API Keys
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# ─── ANALYTICS ─────────────────────────────────────────────────────
POSTHOG_API_KEY=your_posthog_api_key_here        # app.posthog.com → Project → API Key
POSTHOG_HOST=https://app.posthog.com

# ─── ALERTS ────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ─── ERROR TRACKING (Sentry) ────────────────────────────────────────
# Leave empty to disable Sentry in development
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── APP ───────────────────────────────────────────────────────────
APP_ENV=development                              # development | production
SECRET_KEY=generate-a-32-plus-char-random-secret-here
FRONTEND_URL=http://localhost:5173
