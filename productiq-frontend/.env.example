# ─── Frontend Environment Variables ───────────────────────────────
# Copy this file to .env and fill in real values.

# Supabase (use the ANON key, never the service_role key)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# FastAPI backend URL
# In development, use /api to leverage the Vite proxy (see vite.config.ts)
# In production, use the full URL of your deployed backend
VITE_API_URL=/api

# Razorpay (publishable key only — safe for browser)
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id_here

# Sentry (error tracking + performance monitoring)
# Leave empty to disable Sentry in development
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_RELEASE=

# Sentry source map upload (CI only — requires SENTRY_AUTH_TOKEN)
# SENTRY_ORG=your-org
# SENTRY_PROJECT=productiq-frontend
# SENTRY_AUTH_TOKEN=your-auth-token
