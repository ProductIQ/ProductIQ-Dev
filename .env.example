# ══════════════════════════════════════════════════════════════════════════════
# ProductIQ — Centralized Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
#
# This is the SINGLE .env file for the entire monorepo.
#   - Backend (FastAPI / Celery) reads from here
#   - Frontend (Vite) reads from here (via envDir: '../' in vite.config.ts)
#   - Docker Compose reads from here (env_file: ./.env)
#   - Doppler injects these as env vars in production (replaces this file)
#
# SETUP:
#   cp .env.example .env
#   # Fill in real values below, then start dev servers
#
# DOPPLER (production):
#   doppler setup              # link to productiq project
#   doppler run -- uvicorn main:app --reload   # run backend
#   doppler run -- npm run dev                 # run frontend
#
# ══════════════════════════════════════════════════════════════════════════════


# ── APP ───────────────────────────────────────────────────────────────────────
APP_ENV=development                          # development | staging | production
SECRET_KEY=sample  # python -c "import secrets; print(secrets.token_hex(32))"
FRONTEND_URL=http://localhost:5173           # prod: https://yourdomain.com


# ── SUPABASE ──────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=sample
SUPABASE_ANON_KEY=eyJsample
SUPABASE_SERVICE_KEY=sample
DATABASE_URL=sample


# ── FRONTEND (Vite — VITE_ prefix required, baked in at build time) ───────────
VITE_SUPABASE_URL=sample
VITE_SUPABASE_ANON_KEY=sample
VITE_API_URL=/api                            # dev: /api (Vite proxy) | prod: https://api.yourdomain.com
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id   # publishable key — safe for browser


# ── GEMINI AI ─────────────────────────────────────────────────────────────────
# Get from: aistudio.google.com → API Keys
GEMINI_API_KEY=sample
# Optional: add up to 5 more keys for rotation (15 RPM × 6 keys = 90 RPM free tier)
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=
GEMINI_API_KEY_6=
GEMINI_MAX_RPM=10


# ── REDIS ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# Docker Compose (internal): redis://redis:6379/0
# Railway:                   redis://default:PASSWORD@monorail.proxy.rlwy.net:PORT/0


# ── PIPELINE MODE ─────────────────────────────────────────────────────────────
USE_CELERY=false                             # false = BackgroundTasks (dev) | true = Celery (prod)


# ── APIFY (web scraping) ──────────────────────────────────────────────────────
# Get from: apify.com → Settings → Integrations → API Token
APIFY_API_TOKEN=sample
APIFY_AMAZON_ACTOR_ID=codingfrontend/amazon-product-scraper
APIFY_FLIPKART_ACTOR_ID=shahidirfan/flipkart-product-scraper
APIFY_FLIPKART_ACTOR_ID_FALLBACK=maxcopell/flipkart-scraper
APIFY_REVIEWS_ACTOR_ID=junglee/amazon-reviews-scraper
APIFY_WEB_BROWSER_ACTOR_ID=apify/web-scraper


# ── SEARCH APIs ───────────────────────────────────────────────────────────────
# SerpAPI: serpapi.com → Dashboard → API Key
SERPAPI_KEY=sample
# Reddit: reddit.com/prefs/apps → Create App (script type)
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here


# ── PAYMENTS (Razorpay) ───────────────────────────────────────────────────────
# Get from: razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here


# ── ANALYTICS (PostHog) ───────────────────────────────────────────────────────
# Get from: app.posthog.com → Project → Project API Key
POSTHOG_API_KEY=sample
POSTHOG_HOST=https://app.posthog.com


# ── ERROR TRACKING (Sentry) ───────────────────────────────────────────────────
# Get from: sentry.io → Project → Settings → Client Keys (DSN)
SENTRY_DSN=sample                                # Leave empty to disable in development
SENTRY_ENVIRONMENT=development               # development | staging | production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Frontend Sentry (Vite bakes these in at build time)
VITE_SENTRY_DSN=jhrogunru henpg erguerg
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_RELEASE=

# CI only — Sentry source map upload (set in GitHub Actions / Doppler CI config)
# SENTRY_AUTH_TOKEN=your_sentry_auth_token
# SENTRY_ORG=your-sentry-org
# SENTRY_PROJECT=productiq-frontend


# ── ALERTS ────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=                           # Optional: Slack incoming webhook for alerts


# ── OPTIONAL: NEO4J ───────────────────────────────────────────────────────────
# Only needed if migrating knowledge graph from Postgres → Neo4j
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
